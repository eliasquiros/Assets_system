# Copiar a .env y ajustar valores locales. .env nunca se sube al repositorio.

DJANGO_SECRET_KEY=change-me-in-every-environment
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,.localhost

# Conexion a PostgreSQL local (DA01/DA02). Ajustar segun tu instancia.
DB_NAME=activos_fijos
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5430
