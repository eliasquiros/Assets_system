# Copiar a .env y ajustar valores locales. .env nunca se sube al repositorio.

DJANGO_SECRET_KEY=change-me-in-every-environment
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,.localhost

# Conexion a PostgreSQL local (DA01/DA02). Ajustar segun tu instancia.
DB_NAME=activos_fijos
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5430

# Origenes permitidos para CSRF (subdominios del frontend). En dev, los
# origenes literales de Vite bastan. En produccion, usar un comodin que
# cubra todos los subdominios de empresas, ej: https://*.sistema.com (DA16).
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://demo.localhost:5173

# --- Produccion (API unica: backend en api.sistema.com). En dev, sin definir. ---
# En prod: DJANGO_ALLOWED_HOSTS=api.sistema.com y DJANGO_DEBUG=False.
#
# Regex ANCLADO de origenes del frontend permitidos por CORS (coma-separado). El
# ancla ^...$ es obligatoria: sin ella matchea https://evil-sistema.com y, con
# credenciales, cualquier origen podria leer respuestas. Ej:
# DJANGO_CORS_ALLOWED_ORIGIN_REGEXES=^https://[a-z0-9-]+\.sistema\.com$
DJANGO_CORS_ALLOWED_ORIGIN_REGEXES=

# SameSite de las cookies de auth. En prod el frontend (*.sistema.com) y el
# backend (api.sistema.com) son cross-origin: la cookie httpOnly solo viaja con
# None (+ Secure, que se activa solo cuando DEBUG=False). En dev dejar sin
# definir (Lax, mismo origen via proxy de Vite).
DJANGO_AUTH_COOKIE_SAMESITE=

# Conexion a Postgres/Supabase. Con el pooler de Supabase usar modo SESION (o
# conexion directa), NUNCA modo transaccion: django-tenants fija el schema via
# search_path por conexion, y el pooling transaccional puede entregar otro
# backend a mitad de request y filtrar datos entre empresas (RS-002).
# DB_SSLMODE=require y DB_HOST/DB_PORT apuntando al pooler en modo sesion.
DB_SSLMODE=
DB_CONN_MAX_AGE=0

# Token secreto que protege el endpoint interno del recalculo mensual de
# depreciacion (POST /api/internal/depreciacion/), disparado por pg_cron via
# pg_net. Generar uno largo y aleatorio. Vacio => el endpoint responde 503.
# Agendar en Supabase (una vez), 06:00 UTC del dia 1 de cada mes:
#   select cron.schedule('depreciacion-mensual', '0 6 1 * *', $$
#     select net.http_post(
#       url := 'https://<host-del-backend>/api/internal/depreciacion/',
#       headers := jsonb_build_object('X-Internal-Token', '<mismo-token>')
#     );
#   $$);
DJANGO_INTERNAL_TASK_TOKEN=
